---
import Link from '@/components/Link.astro'
import { Image } from 'astro:assets'
import type { CollectionEntry } from 'astro:content'

interface Props {
  piece: CollectionEntry<'art'>
}

const { piece } = Astro.props
---

<Link
  href={`/art/${piece.id}`}
  class="group relative block aspect-square overflow-hidden rounded-xl border"
>
  <Image
    src={piece.data.image}
    alt={piece.data.title}
    width={800}
    height={800}
    class="h-full w-full object-cover transition-transform duration-300 ease-in-out group-hover:scale-105"
  />
  <div
    class="absolute inset-0 flex items-center justify-center bg-black/0 p-3 text-center opacity-0 transition-all duration-300 ease-in-out group-hover:bg-black/50 group-hover:opacity-100"
  >
    <span class="text-sm font-medium text-white sm:text-base">
      {piece.data.title}
    </span>
  </div>
</Link>
