---
import Breadcrumbs from '@/components/Breadcrumbs.astro'
import PageHead from '@/components/PageHead.astro'
import Link from '@/components/Link.astro'
import Layout from '@/layouts/Layout.astro'
import { Icon } from 'astro-icon/components'
import { SITE } from '@/consts'
import { Image } from 'astro:assets'
import portrait from '@/assets/portrait.jpg'


// Experience Timeline - Customize with your own experience
type ExperienceItem = {
  role: string
  company: string
  period: string
  current?: boolean
  icon: string
  key: string
}

// Customize your experience here
const experience: ExperienceItem[] = [
  {
    role: 'Independent Researcher',
    company: 'NYU Courant',
    period: '2024 - Present',
    current: true,
    icon: 'lucide:code',
    key: 'Working with Prof. Dennis Shasha on developing a practice aid for musicians.'
  },
  {
    role: 'President',
    company: 'Columbia Robotics Club',
    period: '2024 - 2026',
    icon: 'lucide:briefcase',
    key: 'Led one of largest engineering student organizations at Columbia, with 200+ members. Organized MakeCU 2025, YC@Columbia 2025.'
  },
  {
    role: 'Computational Research Assistant',
    company: 'Columbia Gang Lab',
    period: '2024 - 2026',
    icon: 'lucide:code',
    key: 'Implemented MOSES, a fundamental algorithm for DNA origami self-assembly. Co-author of paper published in ACS Nano and featured on the front cover.'
  },
]

// Person Schema for About page
const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": SITE.title,
  "url": SITE.href,
  "description": SITE.description
}
---
<Layout class="max-w-3xl">
  <PageHead slot="head" title="About" />
  
  <!-- Person Schema for About page SEO -->
  <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
  
  <Breadcrumbs items={[{ label: 'About', icon: 'lucide:user' }]} />

  <section class="flex flex-col gap-8">
    <!-- Header -->
    <div class="flex flex-col gap-4">
      <div>
        <h1 class="text-3xl md:text-4xl font-bold">About</h1>
        <p class="text-sm text-muted-foreground font-mono mt-1">
          Learn more about me
        </p>
      </div>
    </div>

    <!-- Hero Image -->
    <!-- <Image
      src={portrait}
      alt="Portrait of Sarah"
      widths={[400, 800, 1200, 1600]}
      sizes="(min-width: 768px) 768px, 70vw"
      quality={90}
      class="w-80 h-auto rounded-xl"
    /> -->

    <!-- Main Content -->
    <div class="prose prose-sm dark:prose-invert max-w-none space-y-6">
      <p class="text-muted-foreground leading-relaxed">
        I graduated from Columbia University in 2026 with a degree in CS and math. 
        There, I spent my time writing code in AI-adjacent domains for research and robotics applications. 
      </p>
      <p class="text-muted-foreground leading-relaxed">
        Outside of coding, I love music! I grew up playing classical violin; these days I also play video game jazz and tango music with friends.
        In my spare time, I also draw, write, and shoot photos.
      </p>
      <!-- <p class="text-muted-foreground leading-relaxed">
        I grew up in a small, primarily-white town in North Dakota. I'm glad to have moved out
        from there, and now reside in NYC.
      </p> -->
    </div>
  </section>


  <!-- Experience Timeline -->
  <section class="mt-8">
    <div class="mb-6">
      <h2 class="text-2xl font-semibold mb-2">Experience</h2>
      <p class="text-sm text-muted-foreground">
        Places and people I've worked with
      </p>
    </div>
    
    <div class="space-y-6">
      {experience.map((exp, index) => (
        <div class="relative">
          {index < experience.length - 1 && (
            <div class="absolute left-[11px] top-8 bottom-0 w-px bg-border" aria-hidden="true"></div>
          )}
          
          <div class="flex gap-4">
            <div class={`relative flex-shrink-0 w-6 h-6 rounded-full flex items-center justify-center ring-4 ring-background z-10 ${
              exp.current ? "bg-primary text-primary-foreground shadow-lg shadow-primary/20" : "bg-muted text-muted-foreground"
            }`}>
              <Icon name={exp.icon} class="size-3.5" />
            </div>
            
            <div class="flex-1 pb-2 min-w-0">
              <div class="mb-1">
                <h3 class="font-semibold text-lg leading-tight">{exp.role}</h3>
                <p class="text-sm text-muted-foreground">
                  {exp.company} · {exp.period}
                </p>
              </div>
              <p class="text-sm text-muted-foreground/90 leading-relaxed mt-2">
                {exp.key}
              </p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

</Layout>
