---
import BlogCard from '@/components/BlogCard.astro'
import Link from '@/components/Link.astro'
import PageHead from '@/components/PageHead.astro'
import Skills from '@/components/react/Skills'
import { ErrorBoundary } from '@/components/react/ErrorBoundary'
import { buttonVariants } from '@/components/ui/button'
import Layout from '@/layouts/Layout.astro'
import { Icon } from 'astro-icon/components'
import { getRecentPosts } from '@/lib/data-utils'
import { cn } from '@/lib/utils'
import { SOCIAL_LINKS, ICON_MAP, SITE } from '@/consts'
import type { SocialLink } from '@/types'

// Error handling for fetching recent posts
let latestPosts: Awaited<ReturnType<typeof getRecentPosts>> = []
try {
  latestPosts = await getRecentPosts(SITE.featuredPostCount)
} catch (error) {
  console.error('Error fetching recent posts:', error)
}

// Person Schema for homepage SEO
const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": SITE.title,
  "url": SITE.href,
  "description": SITE.description
}

// Organization Schema
const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": SITE.title,
  "url": SITE.href,
  "description": SITE.description
}

// Website Schema
const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": SITE.title,
  "url": SITE.href,
  "description": SITE.description,
  "potentialAction": {
    "@type": "SearchAction",
    "target": {
      "@type": "EntryPoint",
      "urlTemplate": `${SITE.href}/blog?q={search_term_string}`
    },
    "query-input": "required name=search_term_string"
  }
}

---
<Layout class="max-w-3xl" transition:persist="home-layout">
  <PageHead slot="head" title={SITE.title} fullTitle={true} />
  
  <!-- Schema Markup for SEO -->
  <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
  
  <!-- Header Image -->
  <img
    src="/intro2.png"
    alt="Intro header"
    class="w-full max-w-xl mx-auto h-auto rounded-xl block transition-transform duration-200 hover:scale-102"
    loading="eager"
    fetchpriority="high"
  />

  <!-- Hero Section -->
  <section class="relative overflow-hidden rounded-xl">
    <!-- Gradient Background -->
    <!-- <div class="absolute inset-0 bg-gradient-to-br from-primary/5 via-background to-background" aria-hidden="true"></div> -->

    <!-- Content -->
    <div class="relative z-10">
      <div class="flex flex-col">
        <!-- Main Content -->
        <div class="flex-1 min-w-0 space-y-6">
          <!-- Heading -->
          <div class="space-y-0">
            <h1 class="text-1xl sm:text-3xl md:text-3xl leading-[1.1] font-bold tracking-tight" style="font-variation-settings: 'wght' 700;">
              <span>Sarah Hong</span>
            </h1>
            <p class="text-muted-foreground mt-4 leading-relaxed text-base md:text-lg max-w-xl">
              Hi, I'm <a href="/about" class="text-primary font-bold hover:underline">Sarah!</a> I recently graduated from Columbia University with a degree in CS and math.
              Here you can find my <a href="/projects" class="text-primary font-medium hover:underline">projects</a> and <a href="/blog" class="text-primary font-medium hover:underline">writings</a>, spanning who I am and what I think about.
            </p>
          </div>
          
          <!-- CTA Buttons -->
          <div class="flex flex-wrap items-center gap-3 pt-2">
            <Link href="/blog" class={buttonVariants({ variant: 'default', size: 'lg' })}>
              Read the blog
              <Icon name="lucide:arrow-right" class="size-4" />
            </Link>
            <Link href="/about" class={buttonVariants({ variant: 'outline', size: 'lg' })}>
              <Icon name="lucide:user" class="size-4" />
              About me
            </Link>
            {SOCIAL_LINKS.find(link => link.label === 'Email') && (
              <Link
                href={SOCIAL_LINKS.find(link => link.label === 'Email')!.href}
                class={buttonVariants({ variant: 'outline', size: 'lg' })}
                external
              >
                <Icon name="lucide:mail" class="size-4" />
                Contact me
              </Link>
            )}
          </div>
          
          <!-- Social Icons -->
          <div class="pt-2">
            <ul class="flex flex-wrap items-center gap-2" role="list">
              {SOCIAL_LINKS.map(({ href, label }: SocialLink) => (
                <li>
                  <Link
                    href={href}
                    aria-label={label}
                    title={label}
                    class={buttonVariants({ variant: 'outline', size: 'icon' }) + ' backdrop-blur-sm bg-background/80'}
                    external={href.startsWith('http') || href.startsWith('mailto:')}
                  >
                    <Icon
                      name={
                        ICON_MAP[label as keyof typeof ICON_MAP] ||
                        'lucide:message-circle-question'
                      }
                      class="size-4"
                    />
                  </Link>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

    <!-- Disclaimer -->
  <section class="mt-0 mb-0">
    <div class="max-w-2xl mx-auto">
      <div class="flex items-start gap-3 rounded-lg border border-border bg-muted/30 px-5 py-4">
        <div class="flex-shrink-0 flex size-9 items-center justify-center rounded-lg bg-primary/10 dark:bg-primary/20" aria-hidden="true">
          <Icon name="lucide:octagon-x" class="size-4 text-primary" />
        </div>
        <div class="space-y-1">
          <p class="text-sm font-semibold text-foreground">Disclaimer</p>
          <p class="text-sm text-muted-foreground leading-relaxed">
            (Code aside) I don't use AI to write any of my blog posts.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Skills & Technologies (Optional) -->
  <!-- <section class="mt-12">
    <div class="mb-6">
      <h2 class="text-2xl font-semibold mb-2">Skills & Technologies</h2>
      <p class="text-sm text-muted-foreground">
        Technologies and tools I work with
      </p>
    </div>
    <ErrorBoundary client:load transition:persist="skills-error-boundary">
      <Skills client:load transition:persist="skills-section" />
    </ErrorBoundary>
  </section> -->

  <!-- Latest from the blog -->
  {latestPosts && latestPosts.length > 0 && (
    <section class="mt-12">
      <div class="mb-6 flex items-center justify-between">
        <div>
          <h2 class="text-2xl font-semibold mb-2">Latest Posts</h2>
          <p class="text-sm text-muted-foreground">Recent articles, poems, thoughts</p>
        </div>
        <Link 
          href="/blog" 
          class={buttonVariants({ variant: 'ghost' }) + ' hidden sm:flex items-center gap-1.5'}
        >
          View all
          <Icon name="lucide:arrow-right" class="size-4" />
        </Link>
      </div>
      
      <div class="space-y-2">
        {latestPosts.map((post) => (
          <article>
            <BlogCard entry={post} />
          </article>
        ))}
      </div>
      
      <article class="mt-2 sm:hidden">
        <Link
          href="/blog"
          aria-label="View all blog posts"
          class="group block py-3 px-2 rounded-md border border-border/50 bg-muted/20 hover:bg-muted/40 hover:border-primary/30 transition-all duration-200"
        >
          <div class="flex items-center gap-3">
            <div class="flex-shrink-0 w-10 h-10 rounded-lg bg-primary/10 dark:bg-primary/20 flex items-center justify-center group-hover:bg-primary/20 dark:group-hover:bg-primary/30 transition-colors" aria-hidden="true">
              <Icon name="lucide:library" class="size-5 text-primary" />
            </div>
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2">
                <span class="text-sm font-semibold text-foreground group-hover:text-primary transition-colors">
                  View all posts
                </span>
                <Icon name="lucide:arrow-right" class="size-4 text-primary/70 group-hover:text-primary group-hover:translate-x-0.5 transition-all shrink-0" aria-hidden="true" />
              </div>
              <p class="text-xs text-muted-foreground mt-0.5">
                Explore all articles and tutorials
              </p>
            </div>
          </div>
        </Link>
      </article>
    </section>
  )}

  <!-- Hidden secrets entrance -->
  <a
    href="/secrets"
    aria-label="Secrets"
    title="?"
    class="text-muted-foreground/40 border-border/40 bg-background/70 hover:text-foreground hover:border-border fixed bottom-4 right-4 z-40 rounded-full border p-2 backdrop-blur-sm transition-all hover:opacity-100"
  >
    <Icon name="lucide:fish-symbol" class="size-4" />
  </a>
</Layout>
