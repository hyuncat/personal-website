---
import Breadcrumbs from '@/components/Breadcrumbs.astro'
import PageHead from '@/components/PageHead.astro'
import PillNavBar from '@/components/PillNavBar.astro'
import ProjectCard from '@/components/ProjectCard.astro'
import { PROJECT_NAV_LINKS } from '@/consts'
import Layout from '@/layouts/Layout.astro'
import { getAllProjects } from '@/lib/data-utils'

const projects = await getAllProjects()
---

<Layout class="max-w-3xl">
  <PageHead slot="head" title="Projects" />
  <Breadcrumbs items={[{ label: 'Projects', icon: 'lucide:folder-git-2' }]} />
  <PillNavBar items={PROJECT_NAV_LINKS} class="mx-auto mb-0 flex w-fit" />
  {
    projects.length > 0 ? (
      <ul class="flex flex-col gap-4">
        {projects.map((project) => (
          <li>
            <ProjectCard project={project} />
          </li>
        ))}
      </ul>
    ) : (
      <p class="text-muted-foreground text-center">No projects found.</p>
    )
  }
</Layout>
