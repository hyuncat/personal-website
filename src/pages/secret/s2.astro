---
// Destination for Secret #2. Reachable only via /api/secret + the /secret/*
// middleware gate; SECRET_ROUTES must map the code's hash to "/secret/s2".
import Layout from '@/layouts/Layout.astro'
import PageHead from '@/components/PageHead.astro'
import PostImage from '@/components/PostImage.astro'
---

<Layout class="max-w-2xl">
  <PageHead slot="head" title="Dreaming of brownstones" />
  <section class="mt-6">
  <h1 class="mb-6 text-center text-2xl font-semibold">Dreaming of brownstones</h1>
    <div style="max-width: 520px; margin: 0 auto; text-align: center;">
      <PostImage src={'/secret/s2/burger_squad.png'} alt="Burger squad" size="2xl" caption="Do you remember that dream? Where we buy out a row of brownstones? We promised to have more wine and movie nights, AYCE raids, karaoke, bakeoffs, and that our dogs would be friends." captionOverlay={true}/>
