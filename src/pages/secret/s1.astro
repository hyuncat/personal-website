---
// Destination for Secret #1 ("biboombap"). Reachable only via /api/secret + the
// /secret/* middleware gate; SECRET_ROUTES maps the code's hash to "/secret/biboombap".
// Page images live in public/secret/biboombap/ so the same gate protects them.
import Layout from '@/layouts/Layout.astro'
import PageHead from '@/components/PageHead.astro'
---

<Layout class="max-w-2xl">
  <PageHead slot="head" title="For Jeffrey" />

  <section class="mt-6">
    <h1 class="mb-6 text-center text-2xl font-semibold">For Jeffrey</h1>

    <div class="bb-wrap">
      <div class="bb-frame">
        <img id="bb-img" alt="secret 1 page" />
        <div class="bb-hit">
          <div id="bb-prevArea" aria-label="Previous page"></div>
          <div id="bb-nextArea" aria-label="Next page"></div>
        </div>
      </div>

      <div class="bb-ui">
        <button id="bb-prevBtn" type="button">← Prev</button>
        <span class="bb-counter" id="bb-counter"></span>
        <button id="bb-nextBtn" type="button">Next →</button>
      </div>

      <!-- <div class="bb-hint">Click left/right side or use ← → keys</div> -->
    </div>
  </section>
</Layout>

<style>
  .bb-wrap {
    max-width: 560px;
    margin: 0 auto;
  }
  .bb-frame {
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1;
    border-radius: 14px;
    overflow: hidden;
    background: #111;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.12);
    user-select: none;
  }
  .bb-frame img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
    background: #111;
  }
  .bb-hit {
    position: absolute;
    inset: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
  }
  .bb-hit > div {
    cursor: pointer;
  }
  .bb-ui {
    display: flex;
    gap: 10px;
    justify-content: center;
    align-items: center;
    margin-top: 12px;
  }
  .bb-ui button {
    padding: 8px 12px;
    border-radius: 10px;
    border: 1px solid var(--border);
  }
  .bb-counter {
    font-variant-numeric: tabular-nums;
    opacity: 0.8;
  }
  .bb-hint {
    text-align: center;
    margin-top: 10px;
    opacity: 0.7;
    font-size: 0.95em;
  }
</style>

<script>
  function initBiboombap() {
    const img = document.getElementById('bb-img')
    const counter = document.getElementById('bb-counter')
    const nextArea = document.getElementById('bb-nextArea')
    const prevArea = document.getElementById('bb-prevArea')
    const nextBtn = document.getElementById('bb-nextBtn')
    const prevBtn = document.getElementById('bb-prevBtn')

    if (
      !(img instanceof HTMLImageElement) ||
      !counter ||
      !nextArea ||
      !prevArea ||
      !nextBtn ||
      !prevBtn
    ) {
      return
    }
    // Avoid re-binding the same DOM (e.g. after view-transition navigations).
    if (img.dataset.bound === 'true') return
    img.dataset.bound = 'true'

    const BASE = '/secret/s1/'
    const TOTAL_PAGES = 13
    const pages = Array.from(
      { length: TOTAL_PAGES },
      (_, i) => `${BASE}s1-${i + 1}.png`,
    )

    let idx = 0

    const preload = (src: string) => {
      const im = new Image()
      im.src = src
    }

    const render = () => {
      img.src = pages[idx]
      counter.textContent = `${idx + 1} / ${pages.length}`
      if (idx + 1 < pages.length) preload(pages[idx + 1])
      if (idx - 1 >= 0) preload(pages[idx - 1])
    }

    const next = () => {
      if (idx < pages.length - 1) {
        idx++
        render()
      }
    }

    const prev = () => {
      if (idx > 0) {
        idx--
        render()
      }
    }

    nextArea.addEventListener('click', next)
    prevArea.addEventListener('click', prev)
    nextBtn.addEventListener('click', next)
    prevBtn.addEventListener('click', prev)

    window.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowRight') next()
      if (e.key === 'ArrowLeft') prev()
    })

    render()
  }

  initBiboombap()
  document.addEventListener('astro:page-load', initBiboombap)
</script>
