---
import Layout from '@/layouts/Layout.astro'
import PageHead from '@/components/PageHead.astro'
import Accordion from '@/components/Accordion.astro'
import { Icon } from 'astro-icon/components'
---

<Layout class="max-w-2xl">
  <PageHead slot="head" title="Secrets" />

  <section class="mt-6 w-full mx-auto max-w-xl text-center">
    <div
      class="text-muted-foreground mb-6 rounded-lg border border-border bg-muted/40 px-4 py-3 text-sm"
    >
      ⚠️ Restricted area!
    </div>

    <!-- <h1 class="mb-5 text-2xl font-semibold">Secrets</h1> -->
    <!-- <p class="text-muted-foreground mb-6 text-sm"></p> -->

    <div class="flex flex-row items-center gap-2">
      <input
        id="secret-input"
        type="password"
        placeholder="Password"
        autocomplete="off"
        class="border-border/60 bg-background/80 text-foreground placeholder:text-muted-foreground/60 focus:ring-primary/20 focus:border-primary/50 h-10 min-w-0 flex-1 rounded-md border px-3 text-sm transition-all focus:outline-none focus:ring-2"
      />
      <button
        id="secret-btn"
        aria-label="Enter"
        title="Enter"
        class="bg-primary text-primary-foreground hover:bg-primary/90 focus-visible:ring-ring focus-visible:ring-offset-background inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-md transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2"
      >
        <Icon name="lucide:arrow-right" class="size-4" />
      </button>
    </div>

    <p id="secret-msg" class="mt-3 text-sm" role="alert" aria-live="polite"></p>

    <!-- Hints -->
    <div class="mt-10">
      <div
        class="border-border bg-card/50 divide-border/60 divide-y overflow-hidden rounded-xl border text-left"
      >
        <Accordion title="Secret #1" flush>
          <p class="text-muted-foreground text-sm italic leading-relaxed">
            "There's only one thing I love more than mahjong... it's beating up Koreans
            with my secret identity!"
          </p>
        </Accordion>
        <Accordion title="Secret #2" flush>
          <p class="text-muted-foreground text-sm italic leading-relaxed">
            "Near an Angel lies a missed opportunity. What is it?"
          </p>
        </Accordion>
      </div>
      <p class="text-muted-foreground/70 mt-3 text-xs">(Codes are case-insensitive.)</p>
    </div>
  </section>
</Layout>

<script>
  function initSecrets() {
    const input = document.getElementById('secret-input')
    const btn = document.getElementById('secret-btn')
    const msg = document.getElementById('secret-msg')
    if (!(input instanceof HTMLInputElement) || !btn || !msg) return
    if (btn.dataset.bound === 'true') return
    btn.dataset.bound = 'true'

    // Capture the narrowed element so the type survives inside the closures below
    // (TS drops `instanceof` narrowing of outer variables inside nested functions).
    const field = input

    const setMsg = (text: string, kind: 'muted' | 'error') => {
      msg.textContent = text
      msg.className =
        'mt-3 text-sm ' + (kind === 'error' ? 'text-destructive' : 'text-muted-foreground')
    }

    async function go() {
      const code = (field.value || '').trim()
      if (!code) {
        setMsg("..?", 'muted')
        return
      }
      // setMsg('Checking…', 'muted')
      try {
        const res = await fetch('/api/secret', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ code }),
        })
        const data = (await res.json()) as { dest?: string; error?: string }
        if (res.ok && data.dest) {
          window.location.href = data.dest
          return
        }
        setMsg(data.error || 'Wrong!', 'error')
      } catch {
        setMsg('Something went wrong. Try again.', 'error')
      }
    }

    btn.addEventListener('click', go)
    field.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') go()
    })
  }

  document.addEventListener('astro:page-load', initSecrets)
</script>
